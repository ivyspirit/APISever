# Copy to .env and fill in. NEVER commit the real .env.

# OpenAI API key (server-only; the client never holds a credential).
# Required for the real agent loop; not needed in FAKE_AGENT mode.
OPENAI_API_KEY=

# Chat model for the agent loop (optional; defaults to gpt-4o).
OPENAI_MODEL=gpt-4o

# Whisper model for /stt audio transcription (optional; defaults to whisper-1).
OPENAI_STT_MODEL=whisper-1

# Port the harness server listens on.
PORT=8080

# Absolute path under which the registered sample workspaces live.
WORKSPACES_ROOT=/Users/ivyli/Documents/Projects/workspace

# When "true", /turn streams scripted events with NO OpenAI call (demo fallback).
FAKE_AGENT=false
