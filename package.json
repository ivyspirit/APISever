{
  "name": "voice-agent-harness",
  "version": "0.1.0",
  "private": true,
  "description": "Thin, stateless harness server for a voice-mode coding agent.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "16.4.7",
    "express": "4.21.2"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "20.17.10",
    "tsx": "4.19.2",
    "typescript": "5.7.2"
  }
}
